{
  "name": "tabi_ui",
  "version": "0.1.0",
  "description": "Reusable Dioxus components",
  "type": "module",
  "exports": {
    ".": "./tailwind.config.js",
    "./tailwind.css": { "style": "./assets/tailwind.css"}
  },
  "files": [
    "assets/tailwind.css",
    "tailwind.config.js"
  ],
  "scripts": {
    "tailwindcss": "npx @tailwindcss/cli -i src/tailwind.css -o assets/tailwind.css",
    "tailwindcss:watch": "npx @tailwindcss/cli -i src/tailwind.css -o assets/tailwind.css --watch"
  },
  "keywords": [
    "dioxus",
    "components",
    "tailwind",
    "css",
    "ui"
  ],
  "author": "Ben Bassett <185055731+falineth@users.noreply.github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/falineth/tabi_ui.git"
  },
  "dependencies": {
    "shadcn": "3.8.0",
    "tailwindcss": "4.2.2",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.2.2"
  }
}
